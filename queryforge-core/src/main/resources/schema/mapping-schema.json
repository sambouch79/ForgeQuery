{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/sambouch79/queryforge/schema/mapping.json",
  "title": "QueryForge Mapping Configuration",
  "description": "Schema for QueryForge SQL mapping configuration files",
  "type": "object",
  "required": ["model", "version", "schema", "fields"],
  "properties": {
    "model": {
      "type": "string",
      "pattern": "^[A-Z0-9_]+$",
      "description": "Model identifier (e.g., USER_REPORT, ORDER_SUMMARY)",
      "minLength": 1,
      "maxLength": 50
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic version (MAJOR.MINOR.PATCH)",
      "examples": ["1.0.0", "2.1.3"]
    },
    "schema": {
      "type": "object",
      "required": ["baseTable"],
      "properties": {
        "baseTable": {
          "$ref": "#/definitions/table"
        },
        "joins": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/join"
          }
        }
      }
    },
    "fields": {
      "type": "object",
      "minProperties": 1,
      "description": "Field mappings: output name -> field definition",
      "patternProperties": {
        "^[a-zA-Z0-9_]+$": {
          "oneOf": [
            { "$ref": "#/definitions/simpleField" },
            { "$ref": "#/definitions/functionField" },
            { "$ref": "#/definitions/rawField" },
            { "$ref": "#/definitions/caseField" }
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "table": {
      "type": "object",
      "required": ["name", "alias"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["table", "derived"],
          "description": "Source type (optional, defaults to table)"
        },
        "name": {
          "type": "string",
          "description": "Table name (e.g., users, orders)",
          "minLength": 1
        },
        "alias": {
          "type": "string",
          "description": "Table alias (e.g., u, o)",
          "pattern": "^[a-z][a-z0-9]*$",
          "minLength": 1,
          "maxLength": 5
        }
      },
      "additionalProperties": false
    },
    "join": {
      "type": "object",
      "required": ["type", "table", "conditions"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["INNER", "LEFT", "RIGHT", "FULL"],
          "description": "Join type"
        },
        "table": {
          "$ref": "#/definitions/table"
        },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/joinCondition"
          }
        }
      },
      "additionalProperties": false
    },
    "joinCondition": {
      "type": "object",
      "required": ["left", "operator", "right"],
      "properties": {
        "left": {
          "type": "string",
          "description": "Left side of condition (e.g., u.id)",
          "pattern": "^[a-z][a-z0-9]*\\.[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "operator": {
          "type": "string",
          "enum": ["=", "!=", ">", "<", ">=", "<="],
          "description": "Comparison operator"
        },
        "right": {
          "type": "string",
          "description": "Right side of condition (e.g., a.user_id)",
          "pattern": "^[a-z][a-z0-9]*\\.[a-zA-Z_][a-zA-Z0-9_]*$"
        }
      },
      "additionalProperties": false
    },
    "simpleField": {
      "type": "object",
      "required": ["type", "path"],
      "properties": {
        "type": {
          "const": "field"
        },
        "path": {
          "type": "string",
          "description": "Column path (e.g., u.name, a.city)",
          "pattern": "^[a-z][a-z0-9]*\\.[a-zA-Z_][a-zA-Z0-9_]*$"
        }
      },
      "additionalProperties": false
    },
    "functionField": {
      "type": "object",
      "required": ["type", "name", "args"],
      "properties": {
        "type": {
          "const": "function"
        },
        "name": {
          "type": "string",
          "description": "SQL function name",
          "enum": ["COALESCE", "NVL", "UPPER", "LOWER", "TRIM", "COUNT", "SUM", "AVG", "MAX", "MIN", "CONCAT"]
        },
        "args": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "rawField": {
      "type": "object",
      "required": ["type", "sql"],
      "properties": {
        "type": {
          "const": "raw"
        },
        "sql": {
          "type": "string",
          "description": "Raw SQL expression",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "caseField": {
      "type": "object",
      "required": ["type", "whens"],
      "properties": {
        "type": { "const": "case" },
        "whens": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["when", "then"],
            "properties": {
              "when": { "type": "object" },
              "then": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "else": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}